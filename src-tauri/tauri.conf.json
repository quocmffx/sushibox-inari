{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inari",
  "version": "0.2.0",
  "identifier": "com.sushibox.inari",
  "build": {
    "frontendDist": "../panel/dist",
    "devUrl": "http://localhost:1788",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Inari",
        "width": 400,
        "height": 520,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/32x32.png","icons/128x128.png","icons/128x128@2x.png","icons/icon.icns","icons/icon.ico"]
  }
}